generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Decimal
  image       String
  slug        String      @unique
  gender      String      @default("Unisex")
  category    String      @default("Signature")
  topNotes    String      @default("")
  heartNotes  String      @default("")
  baseNotes   String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  OrderItems  OrderItem[]
  WishlistItems Wishlist[]
  reviews     Review[]
}

model Order {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  total           Decimal
  
  // Statuses
  status          String      @default("PENDING")
  paymentMethod   String      @default("COD")
  paymentStatus   String      @default("PENDING")

  // Shipping Details
  shippingName    String
  shippingAddress String
  city            String
  postalCode      String      @default("")
  country         String      @default("Pakistan")
  phoneNumber     String
  email           String?

  // Relations
  items           OrderItem[]
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  phoneNumber String?
  role        String   @default("USER")
  createdAt   DateTime @default(now())
  orders      Order[]
  wishlist    Wishlist[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  comment   String
  date      String
  createdAt DateTime @default(now())
}

model HomepageConfig {
  id              String   @id @default("singleton")
  // 3D Card 1 (Left)
  card1Name       String   @default("Rose Elixir")
  card1Edition    String   @default("FLORAL ESSENCE")
  card1Image      String   @default("https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&w=800&q=80")
  card1Link       String   @default("/shop")
  
  // 3D Card 2 (Center)
  card2Name       String   @default("Midnight OUD")
  card2Edition    String   @default("SIGNATURE EDITION")
  card2Image      String   @default("https://images.unsplash.com/photo-1594035910387-fea4779426e9?auto=format&fit=crop&w=800&q=80")
  card2Link       String   @default("/shop")
  
  // 3D Card 3 (Right)
  card3Name       String   @default("Velvet Orchid")
  card3Edition    String   @default("ROYAL ORIENTAL")
  card3Image      String   @default("https://images.unsplash.com/photo-1588405765098-936d50953d7e?auto=format&fit=crop&w=800&q=80")
  card3Link       String   @default("/shop")

  // Split Category 1 (For Him)
  split1Title     String   @default("FOR HIM")
  split1Image     String   @default("https://images.unsplash.com/photo-1615655406736-b37c4fabf923?auto=format&fit=crop&w=1000&q=80")
  split1Link      String   @default("/shop?gender=Men")

  // Split Category 2 (For Her)
  split2Title     String   @default("FOR HER")
  split2Image     String   @default("https://images.unsplash.com/photo-1594035910387-fea4779426e9?auto=format&fit=crop&w=1000&q=80")
  split2Link      String   @default("/shop?gender=Women")

  updatedAt       DateTime @updatedAt
}
